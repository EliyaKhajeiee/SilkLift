            "r2_quote": { "type": "text", "settings": { "text": "<p>\"Better than my $300 spa facial. I use it every morning while my coffee brews. Skin is firmer, pores look smaller, and I genuinely look more rested.\"</p>", "width": "100%", "alignment": "left", "type_preset": "paragraph", "font": "var(--font-body--family)", "font_size": "1rem", "line_height": "body-loose", "padding-block-start": 0, "padding-block-end": 0, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} },
