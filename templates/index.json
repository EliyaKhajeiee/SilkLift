          "type": "accordion",
          "settings": {
            "heading": "What is your return policy?",
            "heading_preset": "h5",
            "open_by_default": false,
            "icon": "caret",
            "dividers": true,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_a3_t": {
              "type": "text",
              "settings": {
                "text": "<p>30-day money-back guarantee. If you are not satisfied, contact us for a full refund. Every device also includes a 1-year warranty.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "text_color": "#8A7F78",
