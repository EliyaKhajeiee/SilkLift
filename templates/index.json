                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": ["faq_3_text"]
        },
        "faq_4": {
          "type": "accordion",
          "name": "FAQ 4",
          "settings": {
            "heading": "What's the difference between RF and microcurrent?",
            "heading_preset": "h5",
            "open_by_default": false,
            "icon": "caret",
            "disclosure_heading_preset": "h6",
