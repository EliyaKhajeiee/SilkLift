    "faq_section": {
      "type": "section",
      "blocks": {
        "faq_head": {
          "type": "text",
          "settings": {
            "text": "<h2>Questions? Answered.</h2>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-primary--family)",
            "background": false,
            "background_color": "#00000026",
