            "padding-inline-end": 0
          },
          "blocks": {
            "faq_a2_t": {
              "type": "text",
              "settings": {
                "text": "<p>Yes. SilkLift has three intensity levels so you can start gently and build up. Safe for all skin types including sensitive skin. Avoid use if you have active skin conditions, implanted devices, or are pregnant.</p>",
