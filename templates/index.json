    "faq_section": {
      "type": "section",
      "blocks": {
        "faq_head": { "type": "text", "settings": { "text": "<h2>Questions? Answered.</h2>", "width": "100%", "max_width": "normal", "alignment": "left", "type_preset": "h2", "font": "var(--font-primary--family)", "font_size": "1rem", "line_height": "display-tight", "letter_spacing": "heading-normal", "case": "none", "wrap": "pretty", "text_color": "", "background": false, "background_color": "#00000026", "corner_radius": 0, "padding-block-start": 0, "padding-block-end": 40, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} },
        "faq_a1": { "type": "accordion", "settings": { "heading": "How soon will I see results?", "heading_preset": "h5", "open_by_default": true, "icon": "caret", "dividers": true, "padding-block-start": 0, "padding-block-end": 0, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": { "faq_a1_t": { "type": "text", "settings": { "text": "<p>Most customers notice improved radiance and texture within 1–2 weeks. Visible lifting and firming appears within 4 weeks of consistent daily use.</p>", "type_preset": "rte", "font": "var(--font-body--family)", "font_size": "1rem", "line_height": "body-loose", "text_color": "#8A7F78", "padding-block-start": 12, "padding-block-end": 20, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} } }, "block_order": ["faq_a1_t"] },
        "faq_a2": { "type": "accordion", "settings": { "heading": "Is it safe for all skin types?", "heading_preset": "h5", "open_by_default": false, "icon": "caret", "dividers": true, "padding-block-start": 0, "padding-block-end": 0, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": { "faq_a2_t": { "type": "text", "settings": { "text": "<p>Yes. SilkLift has three intensity levels so you can start gently and build up. Safe for all skin types including sensitive. Avoid use if pregnant or if you have implanted devices.</p>", "type_preset": "rte", "font": "var(--font-body--family)", "font_size": "1rem", "line_height": "body-loose", "text_color": "#8A7F78", "padding-block-start": 12, "padding-block-end": 20, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} } }, "block_order": ["faq_a2_t"] },
        "faq_a3": { "type": "accordion", "settings": { "heading": "What's your return policy?", "heading_preset": "h5", "open_by_default": false, "icon": "caret", "dividers": true, "padding-block-start": 0, "padding-block-end": 0, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": { "faq_a3_t": { "type": "text", "settings": { "text": "<p>30-day money-back guarantee. If you're not satisfied, contact us for a full refund — no questions asked. Every device also includes a 1-year warranty.</p>", "type_preset": "rte", "font": "var(--font-body--family)", "font_size": "1rem", "line_height": "body-loose", "text_color": "#8A7F78", "padding-block-start": 12, "padding-block-end": 20, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} } }, "block_order": ["faq_a3_t"] },
        "faq_a4": { "type": "accordion", "settings": { "heading": "Do I need conductive gel?", "heading_preset": "h5", "open_by_default": false, "icon": "caret", "dividers": true, "padding-block-start": 0, "padding-block-end": 0, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": { "faq_a4_t": { "type": "text", "settings": { "text": "<p>A water-based serum or gel is required for optimal conductivity. You can use any water-based serum you already own, or add our Conductive Peptide Gel to your order.</p>", "type_preset": "rte", "font": "var(--font-body--family)", "font_size": "1rem", "line_height": "body-loose", "text_color": "#8A7F78", "padding-block-start": 12, "padding-block-end": 20, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} } }, "block_order": ["faq_a4_t"] }
      },
