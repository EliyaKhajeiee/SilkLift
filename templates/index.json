        "faq_accordion": {
          "type": "accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h5",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "row1": {
              "type": "_accordion-row",
              "settings": { "heading": "How soon will I see results?", "open_by_default": true },
              "blocks": {
                "text1": { "type": "text", "settings": { "text": "<p>Most customers notice improved radiance and texture within 1-2 weeks. Visible lifting and firming appears within 4 weeks of consistent daily use.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text1"]
            },
            "row2": {
              "type": "_accordion-row",
              "settings": { "heading": "Is it safe for all skin types?", "open_by_default": false },
              "blocks": {
                "text2": { "type": "text", "settings": { "text": "<p>Yes. SilkLift has three intensity levels. Safe for all skin types including sensitive. Avoid use if pregnant or if you have implanted devices.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text2"]
            },
            "row3": {
              "type": "_accordion-row",
              "settings": { "heading": "What is your return policy?", "open_by_default": false },
              "blocks": {
                "text3": { "type": "text", "settings": { "text": "<p>30-day money-back guarantee. If you are not satisfied, contact us for a full refund. Every device also includes a 1-year warranty.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text3"]
            },
            "row4": {
              "type": "_accordion-row",
              "settings": { "heading": "Can I mix colors in a bundle?", "open_by_default": false },
              "blocks": {
                "text4": { "type": "text", "settings": { "text": "<p>Yes. Bundle orders can include any mix of Obsidian Black and Pearl White. Just note your color preference at checkout or contact us after ordering.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text4"]
            },
            "row5": {
              "type": "_accordion-row",
              "settings": { "heading": "Do I need conductive gel?", "open_by_default": false },
              "blocks": {
                "text5": { "type": "text", "settings": { "text": "<p>A water-based serum or gel is required for optimal conductivity. You can use any water-based serum you already own.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text5"]
            }
          },
          "block_order": ["row1","row2","row3","row4","row5"]
        }
      },
