    "faq_section": {
      "type": "section",
      "blocks": {
        "faq_head": {
          "type": "text",
          "settings": {
            "text": "<h2>Questions? Answered.</h2>",
            "width": "100%",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-primary--family)",
            "background": false,
            "background_color": "#00000026",
            "corner_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 40,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "faq_accordion": {
          "type": "accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h5",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "row1": {
              "type": "_accordion-row",
              "settings": { "heading": "How soon will I see results?", "open_by_default": true },
              "blocks": {
                "text1": { "type": "text", "settings": { "text": "<p>Most customers notice improved radiance and texture within 1-2 weeks. Visible lifting and firming appears within 4 weeks of consistent daily use.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text1"]
            },
            "row2": {
              "type": "_accordion-row",
              "settings": { "heading": "Is it safe for all skin types?", "open_by_default": false },
              "blocks": {
                "text2": { "type": "text", "settings": { "text": "<p>Yes. SilkLift has three intensity levels. Safe for all skin types including sensitive. Avoid use if pregnant or if you have implanted devices.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text2"]
            },
            "row3": {
              "type": "_accordion-row",
              "settings": { "heading": "Do I need conductive gel?", "open_by_default": false },
              "blocks": {
                "text3": { "type": "text", "settings": { "text": "<p>Not necessary, but helpful. A water-based serum enhances conductivity and results — you can use any serum you already own.</p>", "width": "100%", "type_preset": "paragraph", "text_color": "#8A7F78", "padding-block-start": 0, "padding-block-end": 16, "padding-inline-start": 0, "padding-inline-end": 0 }, "blocks": {} }
              },
              "block_order": ["text3"]
            }
          },
          "block_order": ["row1","row2","row3"]
        }
      },
      "block_order": ["faq_head","faq_accordion"],
      "settings": {
        "section_width": "page-width",
        "background_color": "",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },

