                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": ["faq_1_text"]
        },
        "faq_2": {
          "type": "accordion",
          "name": "FAQ 2",
          "settings": {
            "heading": "How soon will I see results?",
            "heading_preset": "h5",
            "open_by_default": false,
            "icon": "caret",
            "disclosure_heading_preset": "h6",
            "text_color": "",
            "dividers": true,
            "divider_color": "{{ settings.color_palette.color2 }}",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_2_text": {
              "type": "text",
              "settings": {
                "text": "<p>Most customers notice improved skin texture and radiance within 1–2 weeks. Visible lifting and firming results typically appear within 4 weeks of consistent daily use (10 minutes, 3–5 times per week). Results improve further with continued use over 8–12 weeks.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "body-loose",
                "padding-block-start": 12,
                "padding-block-end": 16,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": ["faq_2_text"]
        },
        "faq_3": {
          "type": "accordion",
          "name": "FAQ 3",
          "settings": {
            "heading": "Can I use it with my existing skincare routine?",
            "heading_preset": "h5",
            "open_by_default": false,
            "icon": "caret",
            "disclosure_heading_preset": "h6",
            "text_color": "",
            "dividers": true,
            "divider_color": "{{ settings.color_palette.color2 }}",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_3_text": {
              "type": "text",
              "settings": {
                "text": "<p>Absolutely. SilkLift works best with a water-based conductive serum or gel (not oil-based). Use it after cleansing and before moisturiser. It actually enhances serum absorption by up to 3×, making the rest of your routine more effective.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "body-loose",
                "padding-block-start": 12,
