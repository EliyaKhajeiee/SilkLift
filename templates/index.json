            "faq_a1_t": {
              "type": "text",
              "settings": {
                "text": "<p>Most customers notice improved radiance and texture within 1–2 weeks. Visible lifting and firming appears within 4 weeks of consistent daily use. Results continue improving over 8–12 weeks.</p>",
