            "icon": "caret",
            "dividers": true,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_a2_t": {
              "type": "text",
              "settings": {
                "text": "<p>Yes. SilkLift has three intensity levels. Safe for all skin types including sensitive. Avoid use if pregnant or if you have implanted devices.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "text_color": "#8A7F78",
                "padding-block-start": 12,
                "padding-block-end": 20,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": ["faq_a2_t"]
        },
