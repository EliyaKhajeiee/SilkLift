        "faq_1": {
          "type": "accordion",
          "name": "FAQ 1",
          "settings": {
            "heading": "Is SilkLift safe for all skin types?",
            "heading_preset": "h5",
            "open_by_default": false,
            "icon": "caret",
            "disclosure_heading_preset": "h6",
            "text_color": "",
            "dividers": true,
            "divider_color": "{{ settings.color_palette.color2 }}",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_1_text": {
              "type": "text",
              "settings": {
                "text": "<p>Yes. SilkLift is designed for all skin types including sensitive skin. The three intensity levels allow you to start low and gradually increase as your skin adapts. If you have any active skin conditions, implanted devices, or are pregnant, please consult a dermatologist before use.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "body-loose",
                "padding-block-start": 12,
