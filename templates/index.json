            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "faq_a4_t": {
              "type": "text",
              "settings": {
                "text": "<p>A water-based serum or gel is required for optimal conductivity. You can use any water-based serum you already own, or add our Conductive Peptide Gel to your order.</p>",
