          "blocks": {
            "faq_a1_t": {
              "type": "text",
              "settings": {
                "text": "<p>Most customers notice improved radiance and texture within 1-2 weeks. Visible lifting and firming appears within 4 weeks of consistent daily use.</p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
