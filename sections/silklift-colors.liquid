{% stylesheet %}
.sl-colors {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-colors__header {
  text-align: center;
  margin-bottom: 52px;
}

.sl-colors__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-colors__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 10px;
}

.sl-colors__heading em { font-style: italic; }

.sl-colors__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

.sl-colors__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  max-width: 1200px;
  margin: 0 auto 48px;
}

.sl-colors__card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.07);
  transition: box-shadow 0.25s;
}

.sl-colors__card:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
}

.sl-colors__img-wrap {
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sl-colors__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.5s ease;
}

/* Landscape device renders — scale down to fit, center them */
.sl-colors__img--device {
  object-fit: scale-down;
  object-position: center center;
  padding: 12px;
  box-sizing: border-box;
}

.sl-colors__img--cover {
  object-fit: cover;
  object-position: center top;
}

.sl-colors__card:hover .sl-colors__img {
  transform: scale(1.03);
}

.sl-colors__info {
  padding: 18px 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: #fff;
}

.sl-colors__dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
}

.sl-colors__name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: #2C2C2C;
  margin: 0;
}

.sl-colors__desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  margin: 0;
}

.sl-colors__cta {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #C9956A;
  text-decoration: none;
  margin-top: 4px;
  transition: opacity 0.2s;
}

.sl-colors__cta:hover { opacity: 0.75; }

.sl-colors__footer {
  text-align: center;
}

@media screen and (max-width: 1023px) {
  .sl-colors__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
}

@media screen and (max-width: 749px) {
  .sl-colors { padding: 60px 20px; }
  .sl-colors__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Colors",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Colors"}]
}
{% endschema %}
