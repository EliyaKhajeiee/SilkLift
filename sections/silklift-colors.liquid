{%- assign sl_product = all_products['silklift-rf-pro'] -%}

{%- comment -%}
  Color config — swatch color, bg, label, url param, fallback asset
{%- endcomment -%}

{%- assign color_names  = 'Obsidian Black,Pearl White,Brushed Silver,Forest Green' | split: ',' -%}
{%- assign color_descs  = 'Sleek. Powerful. Iconic.,Clean. Luminous. Elegant.,Modern. Refined. Minimal.,Bold. Fresh. Confident.' | split: ',' -%}
{%- assign color_swatches = '#1a1a1a,#F5F0EB,#C0C0C0,#2D5E3A' | split: ',' -%}
{%- assign color_bgs    = '#111111,#F0EBE3,#F8F8F8,#F0F5F0' | split: ',' -%}
{%- assign color_params = 'black,white,silver,green' | split: ',' -%}
{%- assign color_assets = 'device-obsidian-black.webp,device-pearl-white.webp,info-silver.webp,device-forest-green.webp' | split: ',' -%}
{%- comment -%} Image indices mapped to actual Shopify media order: Green=0, Black=1, Silver=2, White=3 {%- endcomment -%}
{%- assign color_img_indices = '1,3,2,0' | split: ',' -%}
{%- comment -%} 0=sold out, 1=available — matches color_names order: Black,White,Silver,Green {%- endcomment -%}
{%- assign color_available  = '0,0,0,1' | split: ',' -%}

<div class="sl-colors">
  <div class="sl-colors__header">
    <p class="sl-colors__eyebrow">4 Exclusive Colorways</p>
    <h2 class="sl-colors__heading">One Device. <em>Your Shade.</em></h2>
    <p class="sl-colors__sub">All colors, same clinic-grade technology. Free shipping on every order.</p>
  </div>

  <div class="sl-colors__grid">

    {%- for i in (0..3) -%}
      {%- assign cname   = color_names[i] -%}
      {%- assign cdesc   = color_descs[i] -%}
      {%- assign cswatch = color_swatches[i] -%}
      {%- assign cbg     = color_bgs[i] -%}
      {%- assign cparam  = color_params[i] -%}
      {%- assign casset  = color_assets[i] -%}

      {%- assign img_idx = color_img_indices[i] | times: 1 -%}
      {%- assign product_img = sl_product.images[img_idx] -%}
      {%- assign is_avail = color_available[i] -%}

      <div class="sl-colors__card{% if is_avail == '0' %} sl-colors__card--sold-out{% endif %}">
        <a href="/products/silklift-rf-pro?color={{ cparam }}" class="sl-colors__img-link">
          <div class="sl-colors__img-wrap" style="background:{{ cbg }}">
            {%- if product_img -%}
              <img src="{{ product_img | image_url: width: 2000 }}"
                   alt="SilkLift RF Pro — {{ cname }}"
                   loading="lazy" class="sl-colors__img">
            {%- else -%}
              <img src="{{ casset | asset_url }}"
                   alt="SilkLift RF Pro — {{ cname }}"
                   loading="lazy" class="sl-colors__img">
            {%- endif -%}
            {%- if is_avail == '0' -%}
              <div class="sl-colors__sold-out-badge">Sold Out</div>
            {%- endif -%}
          </div>
        </a>
        <div class="sl-colors__info">
          <span class="sl-colors__dot" style="background:{{ cswatch }}"></span>
          <div class="sl-colors__text">
            <p class="sl-colors__name">{{ cname }}</p>
            <p class="sl-colors__desc">{{ cdesc }}</p>
          </div>
          {%- if is_avail == '1' -%}
            <a href="/products/silklift-rf-pro?color={{ cparam }}" class="sl-colors__cta">Shop {{ cname | split: ' ' | last }} →</a>
          {%- else -%}
            <span class="sl-colors__cta sl-colors__cta--sold-out">Sold Out</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

  </div>

  <div class="sl-colors__footer">
    <a href="/products/silklift-rf-pro" class="sl-btn sl-btn--dark">View All Colors — $99 + Free Shipping</a>
  </div>
</div>

{% stylesheet %}
.sl-colors {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-colors__header {
  text-align: center;
  margin-bottom: 52px;
}

.sl-colors__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-colors__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 10px;
}

.sl-colors__heading em { font-style: italic; }

.sl-colors__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

.sl-colors__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  max-width: 1200px;
  margin: 0 auto 48px;
}

.sl-colors__card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.07);
  transition: box-shadow 0.25s;
}

.sl-colors__card:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
}

.sl-colors__img-wrap {
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sl-colors__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.5s ease;
}

/* Landscape device renders — scale down to fit, center them */
.sl-colors__img--device {
  object-fit: scale-down;
  object-position: center center;
  padding: 12px;
  box-sizing: border-box;
}

.sl-colors__img--cover {
  object-fit: cover;
  object-position: center top;
}

.sl-colors__card:hover .sl-colors__img {
  transform: scale(1.03);
}

.sl-colors__info {
  padding: 18px 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: #fff;
}

.sl-colors__dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
}

.sl-colors__name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: #2C2C2C;
  margin: 0;
}

.sl-colors__desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  margin: 0;
}

.sl-colors__cta {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #C9956A;
  text-decoration: none;
  margin-top: 4px;
  transition: opacity 0.2s;
}

.sl-colors__cta:hover { opacity: 0.75; }

.sl-colors__cta--sold-out {
  color: #B5AFA9;
  cursor: default;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-top: 4px;
}

.sl-colors__card--sold-out .sl-colors__img-wrap {
  filter: grayscale(30%);
}

.sl-colors__sold-out-badge {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 8px 20px;
  white-space: nowrap;
}

.sl-colors__img-wrap {
  position: relative;
}

.sl-colors__footer {
  text-align: center;
}

@media screen and (max-width: 1023px) {
  .sl-colors__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
}

@media screen and (max-width: 749px) {
  .sl-colors { padding: 60px 20px; }
  .sl-colors__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Colors",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Colors"}]
}
{% endschema %}
