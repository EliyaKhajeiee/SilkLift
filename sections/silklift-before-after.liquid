{% stylesheet %}
.sl-ba {
  background: #1a1a1a;
  padding: 80px 40px;
}

.sl-ba__header {
  text-align: center;
  margin-bottom: 52px;
}

.sl-ba__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-ba__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #FAF8F5;
  margin: 0 0 10px;
}

.sl-ba__heading em { font-style: italic; }

.sl-ba__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #8A7F78;
  margin: 0;
}

.sl-ba__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  max-width: 1100px;
  margin: 0 auto 52px;
}

.sl-ba__card {
  overflow: hidden;
  border-radius: 2px;
  aspect-ratio: 3/4;
}

.sl-ba__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.5s ease;
}

.sl-ba__card:hover .sl-ba__img {
  transform: scale(1.03);
}

.sl-ba__cta {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}

.sl-ba__guarantee {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
  margin: 0;
}

.sl-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 18px 32px;
  transition: opacity 0.2s, transform 0.15s;
}
.sl-btn--big { font-size: 0.9rem; padding: 20px 40px; }
.sl-btn:hover { opacity: 0.85; transform: translateY(-1px); }
.sl-btn--dark { background: #FAF8F5; color: #2C2C2C; border: 2px solid #FAF8F5; }

@media screen and (max-width: 749px) {
  .sl-ba { padding: 60px 20px; }
  .sl-ba__grid { grid-template-columns: 1fr; gap: 12px; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Before & After",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Before & After"}]
}
{% endschema %}
