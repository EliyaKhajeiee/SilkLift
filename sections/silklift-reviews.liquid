{% stylesheet %}
.sl-reviews {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-reviews__header {
  text-align: center;
  margin-bottom: 48px;
}

.sl-reviews__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 12px;
}

.sl-reviews__heading em {
  font-style: italic;
}

.sl-reviews__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #8A7F78;
  margin: 0;
}

.sl-reviews__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.sl-review {
  background: #ffffff;
  padding: 40px 36px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.sl-review__stars {
  color: #C9956A;
  letter-spacing: 2px;
  font-size: 1rem;
  margin: 0;
}

.sl-review__quote {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  line-height: 1.7;
  color: #2C2C2C;
  margin: 0;
  flex: 1;
}

.sl-review__author {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

@media screen and (max-width: 749px) {
  .sl-reviews {
    padding: 60px 24px;
  }

  .sl-reviews__grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Reviews",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Reviews"}]
}
{% endschema %}
