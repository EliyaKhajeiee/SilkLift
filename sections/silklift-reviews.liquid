{% stylesheet %}
.sl-reviews {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-reviews__header {
  text-align: center;
  margin-bottom: 48px;
}

.sl-reviews__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-reviews__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 10px;
}

.sl-reviews__heading em { font-style: italic; }

.sl-reviews__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

/* Facebook-style posts */
.sl-fb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  max-width: 1100px;
  margin: 0 auto 48px;
}

.sl-fb-post {
  background: #ffffff;
  border-radius: 8px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sl-fb-post__header {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sl-fb-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  flex-shrink: 0;
}

.sl-fb-avatar--sm {
  width: 32px;
  height: 32px;
  font-size: 0.8rem;
}

.sl-fb-post__name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: #1c1e21;
  margin: 0;
}

.sl-fb-post__time {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #8A8D91;
  margin: 0;
}

.sl-fb-post__text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  line-height: 1.6;
  color: #1c1e21;
  margin: 0;
}

.sl-fb-post__image-wrap {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  border-radius: 4px;
}

.sl-fb-post__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

.sl-fb-post__reactions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A8D91;
}

.sl-fb-post__likes { font-size: 0.82rem; }

.sl-fb-post__divider {
  height: 1px;
  background: #e4e6ea;
}

.sl-fb-post__actions {
  display: flex;
  justify-content: space-around;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: #8A8D91;
}

.sl-fb-post__reply {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.sl-fb-post__reply-bubble {
  background: #f0f2f5;
  border-radius: 16px;
  padding: 8px 14px;
  flex: 1;
}

.sl-fb-post__reply-name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  color: #1c1e21;
  margin: 0 0 2px;
}

.sl-fb-post__reply-bubble p:last-child {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #1c1e21;
  margin: 0;
}

/* Small review cards */
.sl-reviews__more {
  max-width: 1100px;
  margin: 0 auto 48px;
}

.sl-review-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.sl-review-card {
  background: #2C2C2C;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sl-review-card__stars {
  color: #C9956A;
  font-size: 0.9rem;
  margin: 0;
}

.sl-review-card__text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  line-height: 1.6;
  color: #E8DDD0;
  font-style: italic;
  margin: 0;
  flex: 1;
}

.sl-review-card__author {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  margin: 0;
}

.sl-reviews__cta {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.sl-reviews__guarantee {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
  margin: 0;
}

@media screen and (max-width: 749px) {
  .sl-reviews { padding: 60px 24px; }
  .sl-fb-grid { grid-template-columns: 1fr; }
  .sl-review-cards { grid-template-columns: 1fr 1fr; gap: 12px; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

