<div class="sl-videos">
  <div class="sl-videos__header">
    <p class="sl-videos__eyebrow">As Seen On</p>
    <h2 class="sl-videos__heading">Real Women. <em>Real Results.</em></h2>
    <p class="sl-videos__sub">Watch what 10 minutes a day can do</p>
  </div>
  <div class="sl-videos__grid">
    <div class="sl-videos__item">
      <div class="sl-videos__frame">
        {%- comment -%} Replace VIDEO_ID_1 with your YouTube video ID {%- endcomment -%}
        <iframe
          src="https://www.youtube.com/embed/VIDEO_ID_1?rel=0&modestbranding=1"
          title="SilkLift Customer Review"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <p class="sl-videos__caption">"I see a difference every week"</p>
      <p class="sl-videos__author">— Sarah, 38</p>
    </div>
    <div class="sl-videos__item">
      <div class="sl-videos__frame">
        {%- comment -%} Replace VIDEO_ID_2 with your YouTube video ID {%- endcomment -%}
        <iframe
          src="https://www.youtube.com/embed/VIDEO_ID_2?rel=0&modestbranding=1"
          title="SilkLift Before and After"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <p class="sl-videos__caption">"Better than botox for me"</p>
      <p class="sl-videos__author">— Michelle, 44</p>
    </div>
    <div class="sl-videos__item">
      <div class="sl-videos__frame">
        {%- comment -%} Replace VIDEO_ID_3 with your YouTube video ID {%- endcomment -%}
        <iframe
          src="https://www.youtube.com/embed/VIDEO_ID_3?rel=0&modestbranding=1"
          title="SilkLift How To Use"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <p class="sl-videos__caption">"My 10-minute morning ritual"</p>
      <p class="sl-videos__author">— Jennifer, 41</p>
    </div>
  </div>
  <div class="sl-videos__cta">
    <a href="/products/silklift-rf-pro" class="sl-btn sl-btn--dark">Shop SilkLift — $99 + Free Shipping</a>
  </div>
</div>

{% stylesheet %}
.sl-videos {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-videos__header {
  text-align: center;
  margin-bottom: 48px;
}

.sl-videos__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-videos__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 10px;
}

.sl-videos__heading em { font-style: italic; }

.sl-videos__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #8A7F78;
  margin: 0;
}

.sl-videos__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto 48px;
}

.sl-videos__item {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sl-videos__frame {
  position: relative;
  width: 100%;
  aspect-ratio: 9/16;
  background: #2C2C2C;
  overflow: hidden;
}

.sl-videos__frame iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.sl-videos__caption {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.1rem;
  font-style: italic;
  color: #2C2C2C;
  margin: 0;
}

.sl-videos__author {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  color: #8A7F78;
  margin: 0;
}

.sl-videos__cta {
  text-align: center;
}

@media screen and (max-width: 749px) {
  .sl-videos { padding: 60px 24px; }
  .sl-videos__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .sl-videos__frame { aspect-ratio: 9/16; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

