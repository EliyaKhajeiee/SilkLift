<div class="sl-ticker">
  <div class="sl-ticker__track">
    {%- comment -%} Duplicated 3× for seamless infinite loop {%- endcomment -%}
    {%- for pass in (1..3) -%}
      <span class="sl-ticker__item"><span class="sl-ticker__star">★★★★★</span> 4.9 / 5 Rating</span>
      <span class="sl-ticker__sep">✦</span>
      <span class="sl-ticker__item">Free Shipping On All Orders</span>
      <span class="sl-ticker__sep">✦</span>
      <span class="sl-ticker__item">30-Day Money-Back Guarantee</span>
      <span class="sl-ticker__sep">✦</span>
      <span class="sl-ticker__item">Seoul-Born Technology</span>
      <span class="sl-ticker__sep">✦</span>
      <span class="sl-ticker__item">4,800+ Verified Reviews</span>
      <span class="sl-ticker__sep">✦</span>
      <span class="sl-ticker__item">1-Year Warranty Included</span>
      <span class="sl-ticker__sep">✦</span>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.sl-ticker {
  background: #C9956A;
  overflow: hidden;
  padding: 13px 0;
  width: 100%;
}

.sl-ticker__track {
  display: flex;
  align-items: center;
  white-space: nowrap;
  width: max-content;
  animation: sl-ticker-scroll 28s linear infinite;
}

.sl-ticker:hover .sl-ticker__track {
  animation-play-state: paused;
}

@keyframes sl-ticker-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-33.333%); }
}

.sl-ticker__item {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  padding: 0 32px;
  flex-shrink: 0;
}

.sl-ticker__star {
  color: #fff;
  letter-spacing: 2px;
}

.sl-ticker__sep {
  color: rgba(255,255,255,0.5);
  font-size: 0.6rem;
  flex-shrink: 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Ticker",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Ticker"}]
}
{% endschema %}
