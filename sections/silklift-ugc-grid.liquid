{% stylesheet %}
.sl-ugc {
  background: #FAF8F5;
  padding: 80px 40px;
}

.sl-ugc__header {
  text-align: center;
  margin-bottom: 48px;
}

.sl-ugc__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 12px;
}

.sl-ugc__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #2C2C2C;
  margin: 0 0 10px;
}

.sl-ugc__heading em { font-style: italic; }

.sl-ugc__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #8A7F78;
  margin: 0;
}

.sl-ugc__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  max-width: 1100px;
  margin: 0 auto 48px;
}

.sl-ugc__item {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  cursor: pointer;
}

.sl-ugc__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.5s ease;
}

.sl-ugc__item:hover .sl-ugc__img {
  transform: scale(1.04);
}

.sl-ugc__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32px 12px 12px;
  background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.sl-ugc__item:hover .sl-ugc__overlay {
  opacity: 1;
}

.sl-ugc__overlay span {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: #FAF8F5;
  letter-spacing: 0.04em;
}

.sl-ugc__cta {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.sl-ugc__guarantee {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
  margin: 0;
}

@media screen and (max-width: 749px) {
  .sl-ugc { padding: 60px 16px; }
  .sl-ugc__grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .sl-ugc__overlay { opacity: 1; }
  .sl-btn { width: 100%; }
}
{% endstylesheet %}

