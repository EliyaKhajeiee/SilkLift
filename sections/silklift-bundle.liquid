<div class="sl-bundle" id="sl-bundle">
  <div class="sl-bundle__header">
    <p class="sl-bundle__eyebrow">🔥 Spring Sale — Limited Time</p>
    <h2 class="sl-bundle__heading">Stock Up &amp; <em>Save More</em></h2>
    <p class="sl-bundle__sub">Free shipping on every order · 30-day money-back guarantee</p>
  </div>

  <div class="sl-bundle__grid">

    <div class="sl-bundle__card">
      <p class="sl-bundle__qty-label">Buy 1</p>
      <p class="sl-bundle__for">For Yourself</p>
      <div class="sl-bundle__price-block">
        <span class="sl-bundle__price">$99</span>
        <span class="sl-bundle__was">$179</span>
      </div>
      <p class="sl-bundle__saving">You save $80</p>
      <ul class="sl-bundle__features">
        <li>✓ 1x SilkLift RF Pro (your color)</li>
        <li>✓ Free Shipping</li>
        <li>✓ 30-Day Guarantee</li>
        <li>✓ 1-Year Warranty</li>
      </ul>
      <a href="/collections/all" class="sl-bundle__btn sl-bundle__btn--secondary">Add to Cart — $99</a>
      <p class="sl-bundle__per-unit">$99 per device</p>
    </div>

    <div class="sl-bundle__card sl-bundle__card--featured">
      <div class="sl-bundle__badge">⭐ MOST POPULAR</div>
      <p class="sl-bundle__qty-label">Buy 2</p>
      <p class="sl-bundle__for">For You &amp; Family</p>
      <div class="sl-bundle__price-block">
        <span class="sl-bundle__price">$159</span>
        <span class="sl-bundle__was">$358</span>
      </div>
      <p class="sl-bundle__saving sl-bundle__saving--gold">You save $199 · Extra 10% OFF</p>
      <ul class="sl-bundle__features">
        <li>✓ 2x SilkLift RF Pro (mix colors)</li>
        <li>✓ Free Shipping</li>
        <li>✓ 30-Day Guarantee</li>
        <li>✓ 1-Year Warranty on both</li>
        <li>✓ Perfect gift — gift wrapping available</li>
      </ul>
      <a href="/collections/all" class="sl-bundle__btn sl-bundle__btn--primary">Add Bundle — $159</a>
      <p class="sl-bundle__per-unit sl-bundle__per-unit--gold">$79.50 per device</p>
      <p class="sl-bundle__note">Perfect for you and someone you love 💛</p>
    </div>

    <div class="sl-bundle__card">
      <p class="sl-bundle__qty-label">Buy 3</p>
      <p class="sl-bundle__for">Family Pack</p>
      <div class="sl-bundle__price-block">
        <span class="sl-bundle__price">$199</span>
        <span class="sl-bundle__was">$537</span>
      </div>
      <p class="sl-bundle__saving">You save $338 · Extra 25% OFF</p>
      <ul class="sl-bundle__features">
        <li>✓ 3x SilkLift RF Pro (mix colors)</li>
        <li>✓ Free Shipping</li>
        <li>✓ 30-Day Guarantee</li>
        <li>✓ 1-Year Warranty on all</li>
        <li>✓ Gift wrapping available</li>
      </ul>
      <a href="/collections/all" class="sl-bundle__btn sl-bundle__btn--secondary">Add to Cart — $199</a>
      <p class="sl-bundle__per-unit">$66 per device</p>
    </div>

  </div>

  <div class="sl-bundle__trust">
    <span>🚚 Free Shipping on All Orders</span>
    <span>↩ 30-Day Money-Back Guarantee</span>
    <span>🔒 Secure Checkout</span>
    <span>🇰🇷 Authentic Korean Technology</span>
  </div>
</div>

{% stylesheet %}
.sl-bundle {
  background: #1a1a1a;
  padding: 96px 40px;
}

.sl-bundle__header {
  text-align: center;
  margin-bottom: 52px;
}

.sl-bundle__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 14px;
}

.sl-bundle__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #FAF8F5;
  margin: 0 0 12px;
}

.sl-bundle__heading em { font-style: italic; }

.sl-bundle__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

.sl-bundle__grid {
  display: grid;
  grid-template-columns: 1fr 1.08fr 1fr;
  gap: 16px;
  max-width: 960px;
  margin: 0 auto 48px;
  align-items: start;
}

.sl-bundle__card {
  background: #242424;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  position: relative;
}

.sl-bundle__card--featured {
  background: #2a2a2a;
  border: 2px solid #C9956A;
  padding: 44px 24px 32px;
  margin-top: -16px;
}

.sl-bundle__badge {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: #C9956A;
  color: #FAF8F5;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  padding: 5px 16px;
  white-space: nowrap;
}

.sl-bundle__qty-label {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.6rem;
  font-weight: 400;
  font-style: italic;
  color: #FAF8F5;
  margin: 0;
  line-height: 1;
}

.sl-bundle__for {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  color: #8A7F78;
  margin: 0;
}

.sl-bundle__price-block {
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.sl-bundle__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 2.5rem;
  font-weight: 800;
  color: #FAF8F5;
  line-height: 1;
}

.sl-bundle__was {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #8A7F78;
  text-decoration: line-through;
}

.sl-bundle__saving {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 600;
  color: #E8DDD0;
  margin: 0;
}

.sl-bundle__saving--gold { color: #C9956A; }

.sl-bundle__features {
  list-style: none;
  padding: 0;
  margin: 4px 0 0;
  display: flex;
  flex-direction: column;
  gap: 7px;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 14px;
}

.sl-bundle__features li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.83rem;
  color: #E8DDD0;
  line-height: 1.4;
}

.sl-bundle__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 16px 20px;
  transition: opacity 0.2s, transform 0.15s;
  text-align: center;
}

.sl-bundle__btn:hover { opacity: 0.88; transform: translateY(-1px); }

.sl-bundle__btn--primary {
  background: #C9956A;
  color: #FAF8F5;
  border: none;
}

.sl-bundle__btn--secondary {
  background: transparent;
  color: #FAF8F5;
  border: 1.5px solid rgba(255,255,255,0.25);
}

.sl-bundle__btn--secondary:hover { border-color: rgba(255,255,255,0.6); }

.sl-bundle__per-unit {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  text-align: center;
  margin: 0;
}

.sl-bundle__per-unit--gold { color: #C9956A; }

.sl-bundle__note {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  text-align: center;
  font-style: italic;
  margin: 0;
}

.sl-bundle__trust {
  display: flex;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 32px;
  max-width: 960px;
  margin: 0 auto;
}

@media screen and (max-width: 749px) {
  .sl-bundle { padding: 60px 20px; }
  .sl-bundle__grid { grid-template-columns: 1fr; gap: 12px; }
  .sl-bundle__card--featured { margin-top: 0; }
  .sl-bundle__btn { width: 100%; }
  .sl-bundle__trust { gap: 16px; flex-direction: column; align-items: center; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Bundle",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Bundle"}]
}
{% endschema %}
