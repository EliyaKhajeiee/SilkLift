<div class="sl-bundle" id="sl-bundle">
  <div class="sl-bundle__header">
    <p class="sl-bundle__eyebrow">🔥 Spring Sale — Limited Time</p>
    <h2 class="sl-bundle__heading">How Many Would <em>You Like?</em></h2>
    <p class="sl-bundle__sub">The more you buy, the more you save · Free shipping on every order</p>
  </div>

  <div class="sl-bundle__options">

    <label class="sl-bopt">
      <input type="radio" name="sl-bundle-qty" value="1" data-label="Buy Now — $99">
      <div class="sl-bopt__inner">
        <div class="sl-bopt__left">
          <span class="sl-bopt__qty">1 Device</span>
          <span class="sl-bopt__for">For Yourself</span>
        </div>
        <div class="sl-bopt__center">
          <span class="sl-bopt__features">Free Shipping &nbsp;·&nbsp; 30-Day Guarantee &nbsp;·&nbsp; 1-Year Warranty</span>
        </div>
        <div class="sl-bopt__right">
          <span class="sl-bopt__price">$99</span>
          <span class="sl-bopt__was">$179</span>
          <span class="sl-bopt__save">Save $80</span>
          <span class="sl-bopt__per">$99/device</span>
        </div>
      </div>
    </label>

    <label class="sl-bopt sl-bopt--featured">
      <div class="sl-bopt__badge">⭐ MOST POPULAR</div>
      <input type="radio" name="sl-bundle-qty" value="2" data-label="Buy Now — $159" checked>
      <div class="sl-bopt__inner">
        <div class="sl-bopt__left">
          <span class="sl-bopt__qty">2 Devices</span>
          <span class="sl-bopt__for">For You &amp; Family</span>
        </div>
        <div class="sl-bopt__center">
          <span class="sl-bopt__features">Mix Colors &nbsp;·&nbsp; Free Shipping &nbsp;·&nbsp; Gift Wrapping Available</span>
        </div>
        <div class="sl-bopt__right">
          <span class="sl-bopt__price sl-bopt__price--gold">$159</span>
          <span class="sl-bopt__was">$358</span>
          <span class="sl-bopt__save sl-bopt__save--gold">Save $199</span>
          <span class="sl-bopt__per sl-bopt__per--gold">$79.50/device</span>
        </div>
      </div>
    </label>

    <label class="sl-bopt">
      <input type="radio" name="sl-bundle-qty" value="3" data-label="Buy Now — $199">
      <div class="sl-bopt__inner">
        <div class="sl-bopt__left">
          <span class="sl-bopt__qty">3 Devices</span>
          <span class="sl-bopt__for">Family Pack</span>
        </div>
        <div class="sl-bopt__center">
          <span class="sl-bopt__features">Mix Colors &nbsp;·&nbsp; Free Shipping &nbsp;·&nbsp; Gift Wrapping Available</span>
        </div>
        <div class="sl-bopt__right">
          <span class="sl-bopt__price">$199</span>
          <span class="sl-bopt__was">$537</span>
          <span class="sl-bopt__save">Save $338</span>
          <span class="sl-bopt__per">$66/device</span>
        </div>
      </div>
    </label>

  </div>

  <div class="sl-bundle__cta-wrap">
    <a href="/products/silklift-rf-pro" class="sl-btn sl-btn--gold sl-btn--big sl-bundle__cta" id="sl-bundle-cta">
      Buy Now — $159 &nbsp;→
    </a>
    <p class="sl-bundle__cta-note">✓ Free Shipping &nbsp;·&nbsp; ✓ 30-Day Money-Back Guarantee &nbsp;·&nbsp; ✓ Secure Checkout</p>
  </div>

  <div class="sl-bundle__trust">
    <span>🚚 Free Shipping on All Orders</span>
    <span>↩ 30-Day Money-Back Guarantee</span>
    <span>🔒 Secure Checkout</span>
    <span>🇰🇷 Authentic Korean Technology</span>
  </div>
</div>

<script>
(function() {
  var radios = document.querySelectorAll('input[name="sl-bundle-qty"]');
  var cta = document.getElementById('sl-bundle-cta');

  function update() {
    radios.forEach(function(r) {
      var lbl = r.closest('.sl-bopt');
      if (r.checked) {
        lbl.classList.add('sl-bopt--selected');
        if (cta) cta.textContent = r.getAttribute('data-label') + '  →';
      } else {
        lbl.classList.remove('sl-bopt--selected');
      }
    });
  }

  radios.forEach(function(r) { r.addEventListener('change', update); });
  update();
})();
</script>

{% stylesheet %}
.sl-bundle {
  background: #1a1a1a;
  padding: 96px 40px;
}

.sl-bundle__header {
  text-align: center;
  margin-bottom: 48px;
}

.sl-bundle__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0 0 14px;
}

.sl-bundle__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: #FAF8F5;
  margin: 0 0 12px;
}

.sl-bundle__heading em { font-style: italic; }

.sl-bundle__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  color: #8A7F78;
  margin: 0;
}

.sl-bundle__options {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 860px;
  margin: 0 auto 40px;
}

.sl-bopt {
  position: relative;
  display: block;
  cursor: pointer;
  border: 2px solid rgba(255,255,255,0.1);
  background: #242424;
  transition: border-color 0.2s, background 0.2s;
}

.sl-bopt input[type="radio"] {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.sl-bopt--featured {
  border-color: rgba(201,149,106,0.4);
  background: #2a2420;
}

.sl-bopt--selected {
  border-color: #C9956A !important;
  background: #2e2118 !important;
}

.sl-bopt:hover { border-color: rgba(201,149,106,0.6); }

.sl-bopt__badge {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: #C9956A;
  color: #FAF8F5;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  padding: 4px 16px;
  white-space: nowrap;
  z-index: 1;
}

.sl-bopt__inner {
  display: grid;
  grid-template-columns: 160px 1fr auto;
  align-items: center;
  padding: 24px 28px;
  gap: 24px;
}

.sl-bopt__left {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.sl-bopt__qty {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.5rem;
  font-weight: 400;
  font-style: italic;
  color: #FAF8F5;
  line-height: 1;
}

.sl-bopt__for {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #8A7F78;
}

.sl-bopt__center {
  border-left: 1px solid rgba(255,255,255,0.08);
  border-right: 1px solid rgba(255,255,255,0.08);
  padding: 0 24px;
}

.sl-bopt__features {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  line-height: 1.6;
}

.sl-bopt__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  min-width: 110px;
}

.sl-bopt__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 1.8rem;
  font-weight: 800;
  color: #FAF8F5;
  line-height: 1;
}

.sl-bopt__price--gold { color: #C9956A; }

.sl-bopt__was {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  color: #8A7F78;
  text-decoration: line-through;
}

.sl-bopt__save {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  color: #E8DDD0;
  letter-spacing: 0.04em;
}

.sl-bopt__save--gold { color: #C9956A; }

.sl-bopt__per {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  color: #8A7F78;
}

.sl-bopt__per--gold { color: #C9956A; }

.sl-bundle__cta-wrap {
  max-width: 860px;
  margin: 0 auto 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}

.sl-bundle__cta {
  width: 100%;
  font-size: 1rem;
  padding: 22px 32px;
  letter-spacing: 0.08em;
  text-align: center;
}

.sl-bundle__cta-note {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
  margin: 0;
  text-align: center;
}

.sl-bundle__trust {
  display: flex;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 32px;
  max-width: 860px;
  margin: 0 auto;
}

@media screen and (max-width: 749px) {
  .sl-bundle { padding: 60px 20px; }

  .sl-bopt__inner {
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 20px;
  }

  .sl-bopt__center {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 10px 0;
  }

  .sl-bopt__right {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 12px;
  }

  .sl-bundle__trust { gap: 14px; flex-direction: column; align-items: center; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Bundle",
  "tag": "section",
  "settings": [],
  "presets": [{"name": "SilkLift Bundle"}]
}
{% endschema %}
