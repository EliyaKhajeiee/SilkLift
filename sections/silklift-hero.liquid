{%- assign sl_product = all_products['silklift-rf-pro'] -%}

<div class="sl-hero">
  <div class="sl-hero__media">

    {%- if sl_product.images.size > 0 -%}

      <div class="sl-gallery" id="sl-gallery">
        <div class="sl-gallery__slides">
          {%- for img in sl_product.images -%}
            <div class="sl-gallery__slide{% if forloop.index0 == 0 %} sl-gallery__slide--active{% endif %}">
              <img
                src="{{ img | image_url: width: 2400 }}"
                alt="{{ img.alt | default: 'SilkLift RF Pro' }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {% if forloop.first %}fetchpriority="high"{% endif %}
                class="sl-hero__img"
                width="{{ img.width }}"
                height="{{ img.height }}"
              >
            </div>
          {%- endfor -%}
        </div>

        {%- if sl_product.images.size > 1 -%}
          <button class="sl-gallery__arrow sl-gallery__arrow--prev" onclick="slGalleryPrev()" aria-label="Previous">&#8592;</button>
          <button class="sl-gallery__arrow sl-gallery__arrow--next" onclick="slGalleryNext()" aria-label="Next">&#8594;</button>

          <div class="sl-gallery__thumbs">
            {%- for img in sl_product.images -%}
              <button
                class="sl-gallery__thumb{% if forloop.index0 == 0 %} sl-gallery__thumb--active{% endif %}"
                onclick="slGalleryGo({{ forloop.index0 }})"
                aria-label="Photo {{ forloop.index }}"
              >
                <img src="{{ img | image_url: width: 120 }}" alt="" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    {%- else -%}
      <img
        src="{{ 'info-dark-hero.webp' | asset_url }}"
        alt="SilkLift RF Pro"
        loading="eager"
        fetchpriority="high"
        class="sl-hero__img"
        width="996"
        height="1496"
      >
    {%- endif -%}

  </div>

  <div class="sl-hero__content">

    <div class="sl-hero__top">
      <div class="sl-hero__stars">★★★★★</div>
      <span class="sl-hero__rating-text">4.9 / 5 &nbsp;·&nbsp; 4,800+ Reviews</span>
    </div>

    <div class="sl-hero__title-block">
      <p class="sl-hero__eyebrow">Seoul-Born Technology</p>
      <h1 class="sl-hero__title">SilkLift RF&nbsp;Pro</h1>
      <p class="sl-hero__tagline">Clinic-grade lifting. At-home convenience.</p>
    </div>

    <div class="sl-hero__features">
      <div class="sl-hero__feature">Repairs sun damage at the cellular level</div>
      <div class="sl-hero__feature">Rebuilds collagen Botox can't touch — no needles</div>
      <div class="sl-hero__feature">Visible lift in 10 min · Real change in 4 weeks</div>
    </div>

    <div class="sl-hero__divider"></div>

    <div class="sl-hero__price-row">
      <span class="sl-hero__price">$99</span>
      <span class="sl-hero__price-was">$179</span>
      <span class="sl-hero__badge">45% OFF</span>
    </div>

    <div class="sl-hero__colors">
      <p class="sl-hero__colors-label">Color — <strong id="sl-selected-color">Forest Green</strong></p>
      <div class="sl-hero__swatches">
        <button class="sl-swatch sl-swatch--sold-out" aria-label="Obsidian Black (Sold Out)" onclick="slSetColor(this,'Obsidian Black',1,false)" style="background:#1a1a1a" data-available="false"></button>
        <button class="sl-swatch sl-swatch--sold-out" aria-label="Pearl White (Sold Out)" onclick="slSetColor(this,'Pearl White',3,false)" style="background:#F5F0EB;border-color:#ccc" data-available="false"></button>
        <button class="sl-swatch sl-swatch--sold-out" aria-label="Brushed Silver (Sold Out)" onclick="slSetColor(this,'Brushed Silver',2,false)" style="background:#C0C0C0" data-available="false"></button>
        <button class="sl-swatch sl-swatch--active" aria-label="Forest Green" onclick="slSetColor(this,'Forest Green',0,true)" style="background:#2D5E3A" data-available="true"></button>
      </div>
    </div>

    <div class="sl-hero__bundle">
      <label class="sl-hbopt">
        <input type="radio" name="sl-hero-qty" value="1" data-label="Buy Now — $99">
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">1 Device</span>
          <span class="sl-hbopt__mid">For Yourself</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price">$99</span>
            <span class="sl-hbopt__save">Save $80</span>
          </div>
        </div>
      </label>

      <label class="sl-hbopt sl-hbopt--popular">
        <span class="sl-hbopt__badge">MOST POPULAR</span>
        <input type="radio" name="sl-hero-qty" value="2" data-label="Buy Now — $198" checked>
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">2 Devices</span>
          <span class="sl-hbopt__mid">You &amp; Someone You Love</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price sl-hbopt__price--gold">$198</span>
            <span class="sl-hbopt__save sl-hbopt__save--gold">Save $160</span>
          </div>
        </div>
      </label>

      <label class="sl-hbopt">
        <input type="radio" name="sl-hero-qty" value="3" data-label="Buy Now — $297">
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">3 Devices</span>
          <span class="sl-hbopt__mid">Gift the Whole Family</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price">$297</span>
            <span class="sl-hbopt__save">Save $240</span>
          </div>
        </div>
      </label>
    </div>

    {%- assign green_vid = 67159156588848 -%}
    {%- for variant in sl_product.variants -%}
      {%- for opt in variant.options -%}
        {%- if opt contains 'Green' -%}
          {%- assign green_vid = variant.id -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}

    <button
      class="sl-hero__cta"
      id="sl-hero-cta"
      data-variant="{{ green_vid }}"
      type="button"
    >
      Buy Now — $159 &nbsp;→
    </button>

    <div class="sl-hero__trust">
      <span>Free Shipping</span>
      <span class="sl-trust-dot"></span>
      <span>30-Day Guarantee</span>
      <span class="sl-trust-dot"></span>
      <span>1-Year Warranty</span>
    </div>

    <div class="sl-hero__stock">
      <span class="sl-stock-dot"></span>
      In Stock
    </div>

  </div>
</div>

<script>
// Gallery
var slGalIdx = 0;
function slGalleryGo(n) {
  var slides = document.querySelectorAll('.sl-gallery__slide');
  var thumbs = document.querySelectorAll('.sl-gallery__thumb');
  if (!slides.length) return;
  slGalIdx = (n + slides.length) % slides.length;
  slides.forEach(function(s, i) { s.classList.toggle('sl-gallery__slide--active', i === slGalIdx); });
  thumbs.forEach(function(t, i) { t.classList.toggle('sl-gallery__thumb--active', i === slGalIdx); });
}
function slGalleryNext() { slGalleryGo(slGalIdx + 1); }
function slGalleryPrev() { slGalleryGo(slGalIdx - 1); }

// Swipe support
(function() {
  var el = document.getElementById('sl-gallery');
  if (!el) return;
  var startX = 0;
  el.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, {passive: true});
  el.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 40) dx < 0 ? slGalleryNext() : slGalleryPrev();
  }, {passive: true});
})();

var slColorAvailable = true;
function slSetColor(btn, name, idx, available) {
  document.querySelectorAll('.sl-swatch').forEach(function(b){ b.classList.remove('sl-swatch--active'); });
  btn.classList.add('sl-swatch--active');
  slColorAvailable = available;
  var el = document.getElementById('sl-selected-color');
  if (el) el.textContent = available ? name : name + ' — Sold Out';
  var cta = document.getElementById('sl-hero-cta');
  if (cta) {
    var checked = document.querySelector('input[name="sl-hero-qty"]:checked');
    if (!available) {
      cta.textContent = 'Sold Out — Choose Another Color';
      cta.disabled = true;
    } else {
      cta.disabled = false;
      var label = checked ? checked.getAttribute('data-label') : 'Buy Now';
      cta.textContent = label + '  →';
    }
  }
  if (typeof idx !== 'undefined') slGalleryGo(idx);
}

(function() {
  var radios = document.querySelectorAll('input[name="sl-hero-qty"]');
  var cta = document.getElementById('sl-hero-cta');

  function update() {
    radios.forEach(function(r) {
      var lbl = r.closest('.sl-hbopt');
      lbl.classList.toggle('sl-hbopt--selected', r.checked);
      if (r.checked && cta) cta.textContent = r.getAttribute('data-label') + '  →';
    });
  }
  radios.forEach(function(r) { r.addEventListener('change', update); });
  update();

  if (cta) {
    cta.addEventListener('click', function() {
      if (!slColorAvailable || cta.disabled) return;
      var vid = cta.getAttribute('data-variant');
      var checked = document.querySelector('input[name="sl-hero-qty"]:checked');
      var qty = checked ? parseInt(checked.value) : 1;
      cta.textContent = 'Loading checkout…';
      cta.disabled = true;
      window.location.href = '/cart/' + vid + ':' + qty + '?channel=buy_button';
    });
    // Init: Green is in stock
    slColorAvailable = true;
  }
})();
</script>

{% stylesheet %}
/* ── Hero Layout ─────────────────────────────────── */
.sl-hero {
  display: grid;
  grid-template-columns: 52% 48%;
  min-height: 100svh;
  background: #FAF8F5;
}

.sl-hero__media { overflow: hidden; }

.sl-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.sl-hero__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40px 48px 40px 40px;
  gap: 16px;
  overflow-y: auto;
}

/* ── Top strip ───────────────────────────────────── */
.sl-hero__top {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sl-hero__stars {
  color: #C9956A;
  font-size: 0.82rem;
  letter-spacing: 2px;
}

.sl-hero__rating-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
}

/* ── Title block ─────────────────────────────────── */
.sl-hero__title-block { display: flex; flex-direction: column; gap: 6px; }

.sl-hero__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0;
}

.sl-hero__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.8rem, 5vw, 5rem);
  font-weight: 300;
  line-height: 0.95;
  color: #2C2C2C;
  margin: 0;
  letter-spacing: -0.01em;
}

.sl-hero__tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #5A5350;
  margin: 0;
  line-height: 1.4;
}

/* ── Feature pills ───────────────────────────────── */
.sl-hero__features {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sl-hero__feature {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #5A5350;
  padding-left: 14px;
  position: relative;
  line-height: 1.4;
}

.sl-hero__feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 5px;
  height: 1px;
  background: #C9956A;
}

/* ── Divider ─────────────────────────────────────── */
.sl-hero__divider {
  height: 1px;
  background: #E8DDD0;
  margin: 2px 0;
}

/* ── Price ───────────────────────────────────────── */
.sl-hero__price-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sl-hero__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  color: #2C2C2C;
  line-height: 1;
}

.sl-hero__price-was {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #B5AFA9;
  text-decoration: line-through;
}

.sl-hero__badge {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  background: #2C2C2C;
  color: #C9956A;
  padding: 4px 10px;
}

/* ── Color swatches ──────────────────────────────── */
.sl-hero__colors { display: flex; flex-direction: column; gap: 8px; }

.sl-hero__colors-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  color: #2C2C2C;
  margin: 0;
}

.sl-hero__swatches { display: flex; gap: 8px; }

.sl-swatch {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid transparent;
  outline: 2px solid transparent;
  outline-offset: 2px;
  cursor: pointer;
  transition: outline-color 0.15s;
  padding: 0;
}

.sl-swatch--active {
  outline-color: #2C2C2C;
}

.sl-swatch--sold-out {
  position: relative;
  opacity: 0.5;
}

.sl-swatch--sold-out::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 45%, #999 45%, #999 55%, transparent 55%);
  border-radius: 50%;
  pointer-events: none;
}

/* ── Bundle selector ─────────────────────────────── */
.sl-hero__bundle {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sl-hbopt {
  display: block;
  position: relative;
  cursor: pointer;
  border: 1.5px solid #E8DDD0;
  background: #fff;
  transition: border-color 0.15s;
}

.sl-hbopt input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }

.sl-hbopt--popular { border-color: rgba(201,149,106,0.4); background: #FDFAF7; }
.sl-hbopt--selected { border-color: #2C2C2C !important; background: #F6F4F1 !important; }
.sl-hbopt--popular.sl-hbopt--selected { border-color: #C9956A !important; background: #FEF5ED !important; }
.sl-hbopt:hover:not(.sl-hbopt--selected) { border-color: #B5AFA9; }

.sl-hbopt__badge {
  position: absolute;
  top: -9px;
  left: 10px;
  background: #C9956A;
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  padding: 2px 8px;
}

.sl-hbopt__inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  padding: 9px 14px;
  gap: 10px;
}

.sl-hbopt__qty {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #2C2C2C;
}

.sl-hbopt__mid {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: #B5AFA9;
}

.sl-hbopt__right { display: flex; align-items: center; gap: 6px; }

.sl-hbopt__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  color: #2C2C2C;
}

.sl-hbopt__price--gold { color: #C9956A; }

.sl-hbopt__save {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  color: #8A7F78;
  background: #F0EBE3;
  padding: 2px 6px;
}

.sl-hbopt__save--gold { color: #C9956A; background: #FDE8D5; }

/* ── CTA Button ──────────────────────────────────── */
.sl-hero__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2C2C2C;
  color: #FAF8F5;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 18px 24px;
  transition: background 0.2s;
  border: none;
  cursor: pointer;
  width: 100%;
}

.sl-hero__cta:hover:not(:disabled) { background: #1a1a1a; }
.sl-hero__cta:disabled { opacity: 0.7; cursor: default; }

/* ── Trust bar ───────────────────────────────────── */
.sl-hero__trust {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #8A7F78;
  flex-wrap: wrap;
}

.sl-trust-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #D4CCC5;
  flex-shrink: 0;
}

/* ── Stock ───────────────────────────────────────── */
.sl-hero__stock {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #2C2C2C;
  font-weight: 500;
}

.sl-stock-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #4CAF50;
  flex-shrink: 0;
  animation: sl-pulse 2s ease-in-out infinite;
}

@keyframes sl-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

/* ── Gallery ─────────────────────────────────────── */
.sl-hero__media {
  position: relative;
  overflow: hidden;
}

.sl-gallery {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
}

.sl-gallery__slides {
  position: relative;
  flex: 1;
  overflow: hidden;
  min-height: 0;
}

.sl-gallery__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.45s ease;
  pointer-events: none;
}

.sl-gallery__slide--active {
  opacity: 1;
  pointer-events: auto;
}

.sl-gallery__slide .sl-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
}

.sl-gallery__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.85);
  border: none;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  color: #2C2C2C;
  z-index: 10;
  transition: background 0.15s;
  backdrop-filter: blur(4px);
}

.sl-gallery__arrow:hover { background: #fff; }
.sl-gallery__arrow--prev { left: 12px; }
.sl-gallery__arrow--next { right: 12px; }

.sl-gallery__thumbs {
  display: flex;
  gap: 6px;
  padding: 8px 10px;
  background: #F5F0EB;
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
}

.sl-gallery__thumbs::-webkit-scrollbar { display: none; }

.sl-gallery__thumb {
  flex-shrink: 0;
  width: 54px;
  height: 54px;
  border: 2px solid transparent;
  background: none;
  padding: 0;
  cursor: pointer;
  overflow: hidden;
  transition: border-color 0.15s;
}

.sl-gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.sl-gallery__thumb--active { border-color: #2C2C2C; }

/* ── Mobile ──────────────────────────────────────── */
@media screen and (max-width: 749px) {
  .sl-hero { grid-template-columns: 1fr; grid-template-rows: 58svh auto; min-height: unset; }
  .sl-hero__content { padding: 28px 20px 44px; gap: 13px; }
  .sl-hero__title { font-size: clamp(2.2rem, 9vw, 2.8rem); }
  .sl-hero__cta { font-size: 0.85rem; }
}

@media screen and (max-width: 1100px) and (min-width: 750px) {
  .sl-hero__content { padding: 28px 32px 28px 28px; gap: 12px; }
  .sl-hero__title { font-size: clamp(2.2rem, 3.5vw, 3.5rem); }
}
{% endstylesheet %}

