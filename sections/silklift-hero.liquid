<div class="sl-hero">
  <div class="sl-hero__media">
    <img
      src="{{ 'info-dark-hero.webp' | asset_url }}"
      alt="SilkLift RF Pro"
      loading="eager"
      fetchpriority="high"
      class="sl-hero__img"
      width="996"
      height="1496"
    >
  </div>

  <div class="sl-hero__content">

    <div class="sl-hero__top">
      <div class="sl-hero__stars">★★★★★</div>
      <span class="sl-hero__rating-text">4.9 / 5 &nbsp;·&nbsp; 4,800+ Reviews</span>
    </div>

    <div class="sl-hero__title-block">
      <p class="sl-hero__eyebrow">Seoul-Born Technology</p>
      <h1 class="sl-hero__title">SilkLift RF&nbsp;Pro</h1>
      <p class="sl-hero__tagline">Clinic-grade lifting. At-home convenience.</p>
    </div>

    <div class="sl-hero__features">
      <div class="sl-hero__feature">RF + Microcurrent + EMS + Heat</div>
      <div class="sl-hero__feature">10 minutes a day · Results in 4 weeks</div>
      <div class="sl-hero__feature">Safe for all skin types · Dermatologist tested</div>
    </div>

    <div class="sl-hero__divider"></div>

    <div class="sl-hero__price-row">
      <span class="sl-hero__price">$99</span>
      <span class="sl-hero__price-was">$179</span>
      <span class="sl-hero__badge">45% OFF</span>
    </div>

    <div class="sl-hero__colors">
      <p class="sl-hero__colors-label">Color — <strong id="sl-selected-color">Obsidian Black</strong></p>
      <div class="sl-hero__swatches">
        <button class="sl-swatch sl-swatch--active" aria-label="Obsidian Black" onclick="slSetColor(this,'Obsidian Black')" style="background:#1a1a1a"></button>
        <button class="sl-swatch" aria-label="Pearl White" onclick="slSetColor(this,'Pearl White')" style="background:#F5F0EB;border-color:#ccc"></button>
        <button class="sl-swatch" aria-label="Forest Green" onclick="slSetColor(this,'Forest Green')" style="background:#2D5E3A"></button>
        <button class="sl-swatch" aria-label="Brushed Silver" onclick="slSetColor(this,'Brushed Silver')" style="background:#C0C0C0"></button>
      </div>
    </div>

    <div class="sl-hero__bundle">
      <label class="sl-hbopt">
        <input type="radio" name="sl-hero-qty" value="1" data-label="Buy Now — $99">
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">1 Device</span>
          <span class="sl-hbopt__mid">For Yourself</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price">$99</span>
            <span class="sl-hbopt__save">–$80</span>
          </div>
        </div>
      </label>

      <label class="sl-hbopt sl-hbopt--popular">
        <span class="sl-hbopt__badge">BEST VALUE</span>
        <input type="radio" name="sl-hero-qty" value="2" data-label="Buy Now — $159" checked>
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">2 Devices</span>
          <span class="sl-hbopt__mid">You &amp; Family</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price sl-hbopt__price--gold">$159</span>
            <span class="sl-hbopt__save sl-hbopt__save--gold">–$199</span>
          </div>
        </div>
      </label>

      <label class="sl-hbopt">
        <input type="radio" name="sl-hero-qty" value="3" data-label="Buy Now — $199">
        <div class="sl-hbopt__inner">
          <span class="sl-hbopt__qty">3 Devices</span>
          <span class="sl-hbopt__mid">Family Pack</span>
          <div class="sl-hbopt__right">
            <span class="sl-hbopt__price">$199</span>
            <span class="sl-hbopt__save">–$338</span>
          </div>
        </div>
      </label>
    </div>

    <a href="/products/silklift-rf-pro" class="sl-hero__cta" id="sl-hero-cta">
      Buy Now — $159 &nbsp;→
    </a>

    <div class="sl-hero__trust">
      <span>Free Shipping</span>
      <span class="sl-trust-dot"></span>
      <span>30-Day Guarantee</span>
      <span class="sl-trust-dot"></span>
      <span>1-Year Warranty</span>
    </div>

    <div class="sl-hero__stock">
      <span class="sl-stock-dot"></span>
      In Stock · Ships in 1–3 days
    </div>

  </div>
</div>

<script>
function slSetColor(btn, name) {
  document.querySelectorAll('.sl-swatch').forEach(function(b){ b.classList.remove('sl-swatch--active'); });
  btn.classList.add('sl-swatch--active');
  var el = document.getElementById('sl-selected-color');
  if (el) el.textContent = name;
}

(function() {
  var radios = document.querySelectorAll('input[name="sl-hero-qty"]');
  var cta = document.getElementById('sl-hero-cta');
  function update() {
    radios.forEach(function(r) {
      var lbl = r.closest('.sl-hbopt');
      lbl.classList.toggle('sl-hbopt--selected', r.checked);
      if (r.checked && cta) cta.textContent = r.getAttribute('data-label') + '  →';
    });
  }
  radios.forEach(function(r) { r.addEventListener('change', update); });
  update();
})();
</script>

{% stylesheet %}
/* ── Hero Layout ─────────────────────────────────── */
.sl-hero {
  display: grid;
  grid-template-columns: 52% 48%;
  min-height: 100svh;
  background: #FAF8F5;
}

.sl-hero__media { overflow: hidden; }

.sl-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.sl-hero__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40px 48px 40px 40px;
  gap: 16px;
  overflow-y: auto;
}

/* ── Top strip ───────────────────────────────────── */
.sl-hero__top {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sl-hero__stars {
  color: #C9956A;
  font-size: 0.82rem;
  letter-spacing: 2px;
}

.sl-hero__rating-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
}

/* ── Title block ─────────────────────────────────── */
.sl-hero__title-block { display: flex; flex-direction: column; gap: 6px; }

.sl-hero__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0;
}

.sl-hero__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.8rem, 5vw, 5rem);
  font-weight: 300;
  line-height: 0.95;
  color: #2C2C2C;
  margin: 0;
  letter-spacing: -0.01em;
}

.sl-hero__tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #5A5350;
  margin: 0;
  line-height: 1.4;
}

/* ── Feature pills ───────────────────────────────── */
.sl-hero__features {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sl-hero__feature {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #5A5350;
  padding-left: 14px;
  position: relative;
  line-height: 1.4;
}

.sl-hero__feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 5px;
  height: 1px;
  background: #C9956A;
}

/* ── Divider ─────────────────────────────────────── */
.sl-hero__divider {
  height: 1px;
  background: #E8DDD0;
  margin: 2px 0;
}

/* ── Price ───────────────────────────────────────── */
.sl-hero__price-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sl-hero__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  color: #2C2C2C;
  line-height: 1;
}

.sl-hero__price-was {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #B5AFA9;
  text-decoration: line-through;
}

.sl-hero__badge {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  background: #2C2C2C;
  color: #C9956A;
  padding: 4px 10px;
}

/* ── Color swatches ──────────────────────────────── */
.sl-hero__colors { display: flex; flex-direction: column; gap: 8px; }

.sl-hero__colors-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  color: #2C2C2C;
  margin: 0;
}

.sl-hero__swatches { display: flex; gap: 8px; }

.sl-swatch {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid transparent;
  outline: 2px solid transparent;
  outline-offset: 2px;
  cursor: pointer;
  transition: outline-color 0.15s;
  padding: 0;
}

.sl-swatch--active {
  outline-color: #2C2C2C;
}

/* ── Bundle selector ─────────────────────────────── */
.sl-hero__bundle {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sl-hbopt {
  display: block;
  position: relative;
  cursor: pointer;
  border: 1.5px solid #E8DDD0;
  background: #fff;
  transition: border-color 0.15s;
}

.sl-hbopt input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }

.sl-hbopt--popular { border-color: rgba(201,149,106,0.4); background: #FDFAF7; }
.sl-hbopt--selected { border-color: #2C2C2C !important; background: #F6F4F1 !important; }
.sl-hbopt--popular.sl-hbopt--selected { border-color: #C9956A !important; background: #FEF5ED !important; }
.sl-hbopt:hover:not(.sl-hbopt--selected) { border-color: #B5AFA9; }

.sl-hbopt__badge {
  position: absolute;
  top: -9px;
  left: 10px;
  background: #C9956A;
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  padding: 2px 8px;
}

.sl-hbopt__inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  padding: 9px 14px;
  gap: 10px;
}

.sl-hbopt__qty {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #2C2C2C;
}

.sl-hbopt__mid {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: #B5AFA9;
}

.sl-hbopt__right { display: flex; align-items: center; gap: 6px; }

.sl-hbopt__price {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  color: #2C2C2C;
}

.sl-hbopt__price--gold { color: #C9956A; }

.sl-hbopt__save {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  color: #8A7F78;
  background: #F0EBE3;
  padding: 2px 6px;
}

.sl-hbopt__save--gold { color: #C9956A; background: #FDE8D5; }

/* ── CTA Button ──────────────────────────────────── */
.sl-hero__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2C2C2C;
  color: #FAF8F5;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 18px 24px;
  transition: background 0.2s;
}

.sl-hero__cta:hover { background: #1a1a1a; }

/* ── Trust bar ───────────────────────────────────── */
.sl-hero__trust {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #8A7F78;
  flex-wrap: wrap;
}

.sl-trust-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #D4CCC5;
  flex-shrink: 0;
}

/* ── Stock ───────────────────────────────────────── */
.sl-hero__stock {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #2C2C2C;
  font-weight: 500;
}

.sl-stock-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #4CAF50;
  flex-shrink: 0;
  animation: sl-pulse 2s ease-in-out infinite;
}

@keyframes sl-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

/* ── Mobile ──────────────────────────────────────── */
@media screen and (max-width: 749px) {
  .sl-hero { grid-template-columns: 1fr; grid-template-rows: 58svh auto; min-height: unset; }
  .sl-hero__content { padding: 28px 20px 44px; gap: 13px; }
  .sl-hero__title { font-size: clamp(2.2rem, 9vw, 2.8rem); }
  .sl-hero__cta { font-size: 0.85rem; }
}

@media screen and (max-width: 1100px) and (min-width: 750px) {
  .sl-hero__content { padding: 28px 32px 28px 28px; gap: 12px; }
  .sl-hero__title { font-size: clamp(2.2rem, 3.5vw, 3.5rem); }
}
{% endstylesheet %}

