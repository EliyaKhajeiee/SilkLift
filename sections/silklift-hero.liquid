<div class="sl-hero">
  <div class="sl-hero__media">
    <img
      src="{{ 'review-amy.png' | asset_url }}"
      alt="SilkLift RF Pro — Korean beauty device"
      loading="eager"
      fetchpriority="high"
      class="sl-hero__img"
      width="1086"
      height="1448"
    >
  </div>
  <div class="sl-hero__content">

    <div class="sl-hero__rating">
      <span class="sl-hero__stars">★★★★★</span>
      <span class="sl-hero__rating-text">4.9/5 (4,800+ Reviews)</span>
    </div>

    <p class="sl-hero__eyebrow">🇰🇷 &nbsp;Seoul-Born Technology</p>
    <h1 class="sl-hero__title">SilkLift<br><em>RF Pro</em></h1>

    <ul class="sl-hero__bullets">
      <li>✦ &nbsp;Clinic-grade RF lifting — no appointments needed</li>
      <li>⚡ &nbsp;4-in-1: RF, Microcurrent, EMS &amp; Heat</li>
      <li>🕐 &nbsp;10 minutes a day — results in 4 weeks</li>
      <li>🌿 &nbsp;Safe for all skin types</li>
    </ul>

    <div class="sl-hero__sale-banner">🔥 &nbsp;SPRING SALE — 45% OFF &nbsp;·&nbsp; Ends Soon</div>

    <div class="sl-hero__price-row">
      <span class="sl-hero__price-now">$99</span>
      <span class="sl-hero__price-was">$179</span>
      <span class="sl-hero__price-tag">SAVE $80</span>
    </div>

    <div class="sl-hero__colors">
      <p class="sl-hero__colors-label">Color — <strong>Obsidian Black</strong></p>
      <div class="sl-hero__color-options">
        <button class="sl-color-btn sl-color-btn--active" aria-label="Obsidian Black">
          <span class="sl-color-swatch" style="background:#1a1a1a"></span>
          <span>Black</span>
        </button>
        <button class="sl-color-btn" aria-label="Pearl White">
          <span class="sl-color-swatch" style="background:#F5F0EB;border:1px solid #ccc"></span>
          <span>White</span>
        </button>
      </div>
    </div>

    <a href="/collections/all" class="sl-btn sl-btn--dark sl-btn--big">Add to Cart — $99</a>

    <div class="sl-hero__trust">
      <span>✓ Free Shipping</span>
      <span>✓ 30-Day Guarantee</span>
      <span>✓ 1-Year Warranty</span>
    </div>

    <div class="sl-hero__stock">
      <span class="sl-hero__stock-dot"></span>
      In Stock &nbsp;·&nbsp; Ships in 1–3 business days
    </div>

    <div class="sl-hero__payments">
      <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/apple_pay-f6db0077dc7c325b436ecef9f9174a8d.svg" alt="Apple Pay" class="sl-payment-icon">
      <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/google_pay-c66a29c63facf2053bf69352982c958e.svg" alt="Google Pay" class="sl-payment-icon">
      <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/paypal-791bf8e26545d7b5a5e0a5a0f0a5b8ff8d30892c8b1b4f0a35b7b5b0e0e0e0e.svg" alt="PayPal" class="sl-payment-icon" onerror="this.style.display='none'">
      <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/visa-319d545c6fd255c9aad5eeaad21fd6f7f7b4fdbdb1a35ce76d657d08be8af951.svg" alt="Visa" class="sl-payment-icon" onerror="this.style.display='none'">
      <img src="https://cdn.shopify.com/shopifycloud/shopify/assets/payment_icons/master-173035bc8124581983d4efa50cf8626e8553c2b0a8d0b0b0b0a0b0a0b0a0b.svg" alt="Mastercard" class="sl-payment-icon" onerror="this.style.display='none'">
      <span class="sl-hero__payments-label">& more</span>
    </div>

    <a href="#sl-bundle" class="sl-hero__bundle-link">📦 &nbsp;Buy 2–3 and save up to $98 →</a>

  </div>
</div>

{% stylesheet %}
.sl-hero {
  display: grid;
  grid-template-columns: 55% 45%;
  min-height: 100svh;
  background: #FAF8F5;
}

.sl-hero__media {
  position: relative;
  overflow: hidden;
}

.sl-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.sl-hero__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40px 48px 40px 44px;
  gap: 14px;
}

.sl-hero__rating {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sl-hero__stars {
  color: #C9956A;
  font-size: 0.9rem;
  letter-spacing: 1px;
}

.sl-hero__rating-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #8A7F78;
}

.sl-hero__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #C9956A;
  margin: 0;
}

.sl-hero__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3rem, 5.5vw, 5.5rem);
  font-weight: 300;
  line-height: 0.92;
  color: #2C2C2C;
  margin: 0;
}

.sl-hero__title em { font-style: italic; }

.sl-hero__bullets {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.sl-hero__bullets li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #2C2C2C;
  line-height: 1.4;
}

.sl-hero__sale-banner {
  background: #2C2C2C;
  color: #E8DDD0;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 10px 16px;
  text-align: center;
}

.sl-hero__price-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0;
}

.sl-hero__price-now {
  font-family: 'DM Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 700;
  color: #2C2C2C;
}

.sl-hero__price-was {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  color: #8A7F78;
  text-decoration: line-through;
}

.sl-hero__price-tag {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  background: #C9956A;
  color: #FAF8F5;
  padding: 4px 10px;
}

.sl-hero__colors { margin: 0; }

.sl-hero__colors-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #2C2C2C;
  margin: 0 0 8px;
}

.sl-hero__color-options {
  display: flex;
  gap: 8px;
}

.sl-color-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  border: 1.5px solid #D4CCC5;
  background: transparent;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  color: #2C2C2C;
  transition: border-color 0.15s;
}

.sl-color-btn--active { border-color: #2C2C2C; }

.sl-color-swatch {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
}

.sl-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 18px 32px;
  transition: opacity 0.2s, transform 0.15s;
}

.sl-btn--big { font-size: 0.9rem; padding: 20px 32px; }
.sl-btn:hover { opacity: 0.85; transform: translateY(-1px); }
.sl-btn--dark { background: #2C2C2C; color: #FAF8F5; border: 2px solid #2C2C2C; }
.sl-btn--outline { background: transparent; color: #2C2C2C; border: 2px solid #2C2C2C; }
.sl-btn--gold { background: #C9956A; color: #FAF8F5; border: 2px solid #C9956A; }
.sl-btn--ghost { background: transparent; color: #FAF8F5; border: 2px solid rgba(255,255,255,0.5); }

.sl-hero__trust {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
}

.sl-hero__stock {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #2C2C2C;
  font-weight: 500;
}

.sl-hero__stock-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #4CAF50;
  display: block;
  flex-shrink: 0;
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.sl-hero__payments {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.sl-payment-icon {
  height: 24px;
  width: auto;
  opacity: 0.65;
  filter: grayscale(1);
}

.sl-hero__payments-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #8A7F78;
}

.sl-hero__bundle-link {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  color: #C9956A;
  text-decoration: underline;
  text-underline-offset: 3px;
}

@media screen and (max-width: 749px) {
  .sl-hero {
    grid-template-columns: 1fr;
    grid-template-rows: 65svh auto;
    min-height: unset;
  }
  .sl-hero__content { padding: 32px 24px 48px; gap: 12px; }
  .sl-hero__title { font-size: clamp(2.8rem, 12vw, 3.5rem); }
  .sl-btn { width: 100%; }
  .sl-hero__trust { gap: 10px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SilkLift Hero",
  "tag": "section",
  "class": "sl-hero-section",
  "settings": [],
  "presets": [{"name": "SilkLift Hero"}]
}
{% endschema %}
